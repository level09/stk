# ============================================
# STK CONFIGURATION
# ============================================
# Lite mode: uv sync && quart run (just works)
# Full mode: uv sync --extra full (Redis + asyncpg)
# ============================================

# === CORE (Required) ===
SECRET_KEY=3nF3Rn@
QUART_APP=run.py
QUART_DEBUG=1
SECURITY_PASSWORD_SALT=3nF3Rn0
SECURITY_REGISTERABLE=True

# === DATABASE ===
# SQLite used by default (instance/stk.db) - no config needed
# Schema changes are tracked with Alembic migrations
# PostgreSQL (uncomment for production)
#SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:pass@localhost/dbname

# === FULL MODE - Redis + asyncpg (optional) ===
# Uncomment after: uv sync --extra full
#REDIS_URL=redis://localhost:6379/1

# === OAUTH (optional) ===
GOOGLE_AUTH_ENABLED=False
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

GITHUB_AUTH_ENABLED=False
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# For local development only (remove in production)
OAUTHLIB_INSECURE_TRANSPORT=1

# === MAIL (optional) ===
MAIL_SERVER=smtp.sendgrid.net
MAIL_USERNAME=sendgrid
MAIL_PASSWORD=sendgrid_secure_password
SECURITY_EMAIL_SENDER=info@domain.com

# === SESSION & COOKIES ===
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
# Set to True to logout other sessions on login (single session per user)
DISABLE_MULTIPLE_SESSIONS=False

# === QARINA RESEARCH ===
# Required to start research runs.
OPENROUTER_API_KEY=your_openrouter_api_key
SERPER_API_KEY=your_serper_api_key
# Optional account-specific USD estimate per Serper query. Leave 0 to show
# query counts without pretending to know your plan's effective unit price.
SERPER_COST_PER_QUERY=0
# Optional on VPS deployments if YouTube blocks datacenter transcript requests.
# WEBSHARE_PROXY_USERNAME=your_webshare_username
# WEBSHARE_PROXY_PASSWORD=your_webshare_password
MODEL=google/gemini-3.1-flash-lite
KNOWLEDGE_MODEL=deepseek/deepseek-chat
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
QUARINA_MAX_CONCURRENT_RUNS=2

# ============================================
# DOCKER CONFIGURATION (docker compose up)
# ============================================
#COMPOSE_PROJECT_NAME=stk
#PYTHONUNBUFFERED=true
#DOCKER_UID=1000
#DB_PASSWORD=verystrongpass
#REDIS_PASSWORD=verystrongpass
#SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://stk:${DB_PASSWORD}@postgres/stk
#REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
